%===================================================================
% COMANDOS AUXILIARES
%===================================================================

\newcommand{\tsup}[1]{\textsuperscript{#1}}
\newcommand{\tsub}[1]{\textsubscript{#1}}

% \aref usa \autoref, que vem do hyperref.
% O hyperref e carregado mais abaixo.
\newcommand{\aref}[1]{\autoref{#1}}

%===================================================================
% INFORMACOES DO DOCUMENTO
%===================================================================

\makeatletter

\newcommand{\instituicao}[1]{\def\uira@instituicao{#1}}
\newcommand{\competicao}[1]{\def\uira@competicao{#1}}
\newcommand{\equipe}[1]{\def\uira@equipe{#1}}
\newcommand{\disciplina}[1]{\def\uira@disciplina{#1}}
\newcommand{\alunos}[1]{\def\uira@alunos{#1}}
\newcommand{\numeroEquipe}[1]{\def\uira@numeroEquipe{#1}}
\newcommand{\email}[1]{\def\uira@email{#1}}
\newcommand{\orientador}[1]{\def\uira@orientador{#1}}
\newcommand{\logounifei}[1]{\def\uira@logounifei{#1}}
\newcommand{\logoequipe}[1]{\def\uira@logoequipe{#1}}
\newcommand{\logoaero}[1]{\def\uira@logoaero{#1}}
\newcommand{\logocapa}[1]{\def\uira@logocapa{#1}}
\newcommand{\datarelatorio}[1]{\def\uira@data{#1}}

\makeatother

%===================================================================
% PAGINA INICIAL
%===================================================================

\makeatletter

\newcommand{\maketitlepage}{%
	\begin{titlepage}
	    \newgeometry{top=1cm,bottom=1cm,left=2cm,right=2cm}
	    \begin{adjustwidth}{-1.5cm}{-1.5cm}
	    
		\centering
        
        \textbf{\LARGE \uira@instituicao}\\[0.5cm]
        \textbf{\Large \uira@competicao}\\[1.0cm]
        
        \vfill
        
        \ifx\uira@logocapa\empty
        \else
            \includegraphics[width=1\textwidth]{\uira@logocapa}\\
        \fi
        
        \vfill
        
	    \rule{\linewidth}{0.2mm}\\[0.4cm]
        {%
            \LARGE \bfseries \uira@disciplina \\[0.4cm]
            \LARGE N\textdegree{} \uira@numeroEquipe{} - \uira@equipe
        }\\
	    \rule{\linewidth}{0.2mm}\\
        
        \vfill
        
        \begin{multicols}{2}
            \large \uira@alunos
        \end{multicols}
        
        \vfill
        
        {\large \textbf{Orientador:} \uira@orientador}\\[0.2cm]
        {\large \uira@email}\\
        
        \vfill
        
	    {\large \uira@data}
	    
	    \end{adjustwidth}
	    \restoregeometry
        \clearpage
	\end{titlepage}
}

\makeatother

%===================================================================
% ESTILOS DE PAGINA
%===================================================================

\RequirePackage{lastpage}

\makeatletter

% Cabecalho padrao
\newcommand{\uira@cabecalho}[1]{%
    \begingroup
    \renewcommand{\arraystretch}{0.85}%
    \footnotesize
    \begin{tabularx}{\textwidth}{@{}L R@{}}
        \vspace{-0.4cm}
        \nouppercase{#1} & 
        \includegraphics[height=6mm]{\uira@logoaero}
    \end{tabularx}%
    \hrule
    \endgroup
}

% Rodape
\newcommand{\uira@rodape}{%
    \hrule
    \scriptsize
    \vspace{1.0mm}
    \uira@competicao \hfill Página: \thepage\space de \pageref{LastPage}
}

% Estilo principal
\fancypagestyle{IHA-fancy-plain}{%
    \fancyhf{}
    \fancyhead[C]{\uira@cabecalho{\leftmark}}
    \fancyfoot[C]{\uira@rodape}
    \renewcommand{\headrulewidth}{0pt}
    \renewcommand{\footrulewidth}{0pt}
}

% Estilo do sumario
\fancypagestyle{ToC}{%
    \fancyhf{}
    \fancyhead[C]{\uira@cabecalho{\textbf{\leftmark}}}
    \fancyfoot[C]{\uira@rodape}
    \renewcommand{\headrulewidth}{0pt}
    \renewcommand{\footrulewidth}{0pt}
}

% Estilo plain usado automaticamente em inicio de capitulos
\fancypagestyle{plain}{%
    \fancyhf{}
    \fancyhead[C]{\uira@cabecalho{\textbf{\leftmark}}}
    \fancyfoot[C]{\uira@rodape}
    \renewcommand{\headrulewidth}{0pt}
    \renewcommand{\footrulewidth}{0pt}
}

% Garante que o documento comece usando o estilo correto
\AtBeginDocument{%
    \pagestyle{IHA-fancy-plain}
}

\makeatother

%===================================================================
% ESTILO DOS CAPITULOS
%===================================================================

\makeatletter

\renewcommand{\@makechapterhead}[1]{%
	{%
    \setlength{\parindent}{4em}
    \raggedright
    \normalfont
	\bfseries\LARGE
    \thechapter~#1
    \par\nobreak
    \vspace{0.5cm}
	}%
}

\renewcommand{\@makeschapterhead}[1]{%
	\vspace*{0pt}%
	{%
    \setlength{\parindent}{4em}
    \raggedright
    \normalfont
	\bfseries\Large
    #1
    \par\nobreak
    \vspace{1cm}
	}%
}

\makeatother

