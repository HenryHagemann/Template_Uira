{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "LaTeX Lint",
      "type": "shell",
      "command": "texlua",
      "args": [
        "${workspaceFolder}/tools/lint_tex.lua"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      },
      "problemMatcher": {
        "owner": "latex-lint",
        "source": "lint-tex",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+?):(\\d+):(\\d+):\\s+(warning|info|error):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      },
    },
    {
      "label": "LaTeX Lint — Watch",
      "type": "shell",
      "command": "texlua",
      "args": [
        "${workspaceFolder}/tools/lint_tex.lua"
      ],
      "isBackground": false,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      },
      "problemMatcher": {
        "owner": "latex-lint",
        "source": "lint-tex",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+?):(\\d+):(\\d+):\\s+(warning|info|error):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    },
    {
      "label": "Setup: Install Dependencies",
      "detail": "Instala PyAeroCounter (Python), Tesseract, MiKTeX, Strawberry Perl, Inkscape e extensoes do VS Code.",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/tools/setup.ps1"
      ],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      }
    },
    {
      "label": "SAE Word Count: Setup",
      "type": "process",
      "command": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}\\tools\\setup_pyaerocounter.ps1"
      ],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      },
      "detail": "Baixa o codigo-fonte do PyAeroCounter e valida dependencias. Executar apos clonar o repositorio."
    },
    {
      "label": "SAE Word Count",
      "type": "process",
      "command": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}\\tools\\count_words.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      },
      "detail": "Conta palavras do main.pdf usando o script Python do PyAeroCounter. Demora varios minutos."
    }
  ]
}
